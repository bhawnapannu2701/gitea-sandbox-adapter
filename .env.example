# Copy this file to .env for local execution. The real .env file is ignored
# by Git and must contain locally generated credentials only.

# Compose identity. Keep this stable if you want to preserve named volumes.
COMPOSE_PROJECT_NAME=gitea_sandbox_adapter

# Pinned images required for Phase 2. Do not use latest or rolling tags.
GITEA_IMAGE=docker.gitea.com/gitea:1.27.0-rootless
POSTGRES_IMAGE=docker.io/library/postgres:16.14-bookworm

# Host ports. Internal container ports remain 3000 for HTTP and 2222 for SSH.
GITEA_HTTP_PORT=3000
GITEA_SSH_PORT=2222

# PostgreSQL settings. Replace POSTGRES_PASSWORD in the real .env file.
POSTGRES_DB=gitea
POSTGRES_USER=gitea
POSTGRES_PASSWORD=replace-with-a-generated-local-password

# Local Gitea administrator used only inside this sandbox.
GITEA_ADMIN_USER=sandbox-admin
GITEA_ADMIN_PASSWORD=replace-with-a-generated-local-password
GITEA_ADMIN_EMAIL=sandbox-admin@example.invalid
GITEA_TOKEN_NAME=gitea-sandbox-phase-2

# Runtime bounds in seconds.
GITEA_START_TIMEOUT=240
GITEA_STOP_TIMEOUT=90
GITEA_HEALTH_POLL_INTERVAL=3
GITEA_HTTP_TIMEOUT=20
GITEA_HTTP_RETRIES=3
GITEA_BROWSER_TIMEOUT=30000
